# ครอบเฉพาะปลั๊กอิน Next.js บังคับให้มันจับพาร์ทให้ถูกร่อง
[[plugins]]
package = "@netlify/plugin-nextjs"

[build]
# ล็อกฐานที่มั่นไว้ที่นอกสุดของโปรเจกต์
base = "apps/letter-luv-app"

# ใช้ pnpm exec นำหน้าเพื่อให้ตามไปขุด nx ในเครื่องมาทำงานได้ทันที
command = "pnpm run build"

# ล็อกพิกัดผลลัพธ์โฟลเดอร์ฝั่งหน้าบ้านของ Next.js ตัวจริง
publish = ".next"

# [build.environment]
# NODE_VERSION = "20"
